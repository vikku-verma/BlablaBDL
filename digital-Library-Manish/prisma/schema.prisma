// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  displayName  String?
  organization String?
  state        String?
  role         String         @default("Subscriber")
  status       String         @default("Active")
  isBlocked    Boolean        @default(false)
  isFirstLogin Boolean        @default(false)
  
  isDemoAccount Boolean       @default(false)
  demoExpiresAt DateTime?

  institution  Institution?   @relation(fields: [institutionId], references: [id])
  institutionId String?
  
  institutionProfile Json?    @default("{}")
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  payments              Payment[]
  subscriptions         Subscription[]
  quotations            Quotation[]
  submissions           Submission[]
  usageLogs             UsageLog[]
  subscriptionRequests  SubscriptionRequest[]
  activities            StudentActivity[]
  couponUsages          CouponUsage[]
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String?  @unique
  paymentId String?  @unique
  amount    Float
  status    String   @default("Pending")
  method    String?  @default("Razorpay")
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  
  items     Json
  createdAt DateTime @default(now())
}

model Subscription {
  id             String   @id @default(uuid())
  domainId       String?
  domainName     String?
  planName       String
  planType       String   @default("Monthly")   // Monthly | Yearly | Custom
  durationMonths Int      @default(1)
  duration       String?  // deprecated label field (kept for compat)
  status         String   @default("Active")   // Active | Expired | Cancelled
  
  domains        Json?    @default("[]")
  contentTypes   Json?    @default("[]")
  allowedContentTypes Json? @default("[]") // Adding for legacy compatibility
  
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  
  institution    Institution? @relation(fields: [institutionId], references: [id])
  institutionId  String?
  
  request        SubscriptionRequest? @relation(fields: [requestId], references: [id])
  requestId      String?  @unique
  
  startDate      DateTime @default(now())
  endDate        DateTime
  cancelledAt    DateTime?
  createdAt      DateTime @default(now())
}

model SubscriptionRequest {
  id             String   @id @default(uuid())
  userName       String
  email          String
  planType       String   @default("Monthly")   // Monthly | Yearly | Custom
  durationMonths Int      @default(1)
  planDescription String? // e.g. "All Domains Package"
  paymentRef     String?  // screenshot URL or payment reference
  notes          String?
  status         String   @default("Pending")   // Pending | Approved | Rejected
  rejectionNote  String?
  
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  
  subscription   Subscription?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Quotation {
  id                String   @id @default(uuid())
  userEmail         String
  userName          String
  organization      String?
  state             String?
  items             Json
  subtotal          Float
  gstAmount         Float
  total             Float
  status            String   @default("Pending")  // Pending | Approved | Paid | Cancelled

  // Dynamic pricing fields
  selectedModules   Json?    @default("[]")       // Array of ContentModule IDs selected
  pricingBreakdown  Json?    @default("{}")        // { modules: [{id, domain, contentType, price}], planType, subtotal, gst, total }
  planType          String?  @default("Monthly")   // Monthly | Quarterly | Yearly
  allowedDomain     String?  // null means all domains
  notes             String?

  user              User?    @relation(fields: [userId], references: [id])
  userId            String?
  
  createdBy         String?  // The user ID or email of the person who generated the quotation (Admin or Self)
  sentEmailHtml     String?  // The exact HTML template that was emailed to the user

  createdAt         DateTime @default(now())
  expiresAt         DateTime
  
  discountAmount    Float?   @default(0.0)
  couponCode        String?
}

model ContentModule {
  id                String   @id @default(uuid())
  domain            String
  contentType       String
  userType          String   @default("General")   // General | Student Scholar | College Excellence | University Global | Corporate Innovator
  totalCount        Int      @default(0)
  monthlyPrice      Float    @default(0)
  quarterlyPrice    Float    @default(0)
  halfYearlyPrice   Float    @default(0)
  yearlyPrice       Float    @default(0)
  yearlyDiscountPct Float    @default(0)   // e.g. 20 means 20% off yearly
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt @default(now())

  @@unique([domain, contentType, userType])
}

model Submission {

  id              String   @id @default(uuid())
  title           String
  authors         String
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  publishingMode  String
  status          String   @default("Pending")
  
  user            User?    @relation(fields: [userId], references: [id])
  userId          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  content         Content?
}

model Content {
  id              String   @id @default(uuid())
  title           String
  description     String?
  authors         String
  domain          String?
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  thumbnailUrl    String?
  tags            Json?    @default("[]")
  price           Float?   @default(0.0)
  accessType      String   @default("Subscription")
  status          String   @default("Published")
  publishingMode  String   @default("Direct")
  views           Int      @default(0)

  // ── Viewer-Based Validation ─────────────────────────────
  validationStatus  String?   @default("Not Validated") // "Not Validated" | "VALID_VIEWABLE" | "FLAGGED_CONTENT"
  viewerStatus      String?                              // "Rendered OK" | "Load Failed" | "Timeout" | "No File" | "Not PDF/Video"
  isViewable        Boolean?  @default(false)
  flaggedReason     String?
  lastValidatedAt   DateTime?

  fingerprint     String?   @unique  // SHA-256 of normalized title+authors

  submission      Submission? @relation(fields: [submissionId], references: [id])
  submissionId    String?     @unique
  
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  
  studentActivities StudentActivity[]
}

model AccessRequest {
  id            String   @id @default(uuid())
  institution   String
  contactPerson String
  email         String
  phone         String
  requestType   String   @default("Trial")
  status        String   @default("Pending")
  
  createdAt     DateTime @default(now())
}

model UsageLog {
  id            String   @id @default(uuid())
  action        String
  details       String?
  points        Int?     @default(0)
  
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  
  createdAt     DateTime @default(now())
}

model Institution {
  id              String   @id @default(uuid())
  name            String
  subscriptionId  String?  @unique
  status          String   @default("Active")
  
  users           User[]
  subscriptions   Subscription[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StudentActivity {
  id          String   @id @default(uuid())
  
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  
  content     Content? @relation(fields: [contentId], references: [id])
  contentId   String?
  
  timeSpent   Int      @default(0)
  lastPage    Int      @default(1)
  accessedAt  DateTime @default(now()) @updatedAt

  @@index([userId, contentId])
}

model Bundle {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  domains         Json     @default("[]")
  contentTypes    Json     @default("[]")
  price           Float    @default(0.0)
  durationMonths  Int      @default(1)
  status          String   @default("Active")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ValidationReport {
  id                 String   @id @default(uuid())
  type               String   // "Manual" | "Automatic"
  validationType     String   @default("Metadata")  // "Metadata" | "ViewerBased" | "Full"
  status             String   @default("Draft") // "Draft" | "Reviewing" | "Resolved"
  totalItemsScanned  Int      @default(0)
  issuesFound        Int      @default(0)
  validCount         Int      @default(0)   // Items confirmed VALID_VIEWABLE
  flaggedCount       Int      @default(0)   // Items confirmed FLAGGED_CONTENT
  issues             Json     // Array of issue details { contentId, title, issueType, description }
  draftedContentIds  Json     @default("[]") // Persisted list of content IDs moved to Draft
  timeline           Json     @default("[]") // Audit trail: [{ action, by, at, count, note }]

  startedAt          DateTime @default(now())
  completedAt        DateTime?
}

model AgencyInquiry {
  id             String   @id @default(uuid())
  agencyName     String
  contactPerson  String
  email          String
  phone          String
  region         String
  experience     String
  message        String?
  status         String   @default("Pending") // Pending | Accepted | Rejected
  discount       Int?     // 30 or 40
  validUntil     DateTime? // Expiration date for the partnership
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContactInquiry {
  id           String   @id @default(uuid())
  fullName     String
  email        String
  mobile       String?
  whatsapp     String?
  designation  String?
  departments  Json?    @default("[]")   // Array of department strings
  state        String?
  organization String?
  message      String
  status       String   @default("New")  // New | Read | Replied | Resolved | Archived
  adminNotes   String?
  replyText    String?
  repliedAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  id                 String        @id @default(uuid())
  code               String        @unique
  discountType       String        @default("percentage") // "percentage" | "fixed"
  discountValue      Float
  maxUses            Int?          // null means unlimited
  usedCount          Int           @default(0)
  validFrom          DateTime?
  validUntil         DateTime?
  isActive           Boolean       @default(true)
  minimumOrderAmount Float?

  usages             CouponUsage[]
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model CouponUsage {
  id         String   @id @default(uuid())
  
  coupon     Coupon   @relation(fields: [couponId], references: [id])
  couponId   String
  
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  
  orderId    String?  // Reference to Quotation ID or Payment ID
  discount   Float    // The actual discount amount applied
  
  usedAt     DateTime @default(now())
}

model DemoRequest {
  id                 String   @id @default(uuid())
  fullName           String
  institutionalEmail String
  institutionName    String
  designation        String?
  whatsappNumber     String?
  city               String?
  state              String?
  department         String
  requestType        String?  @default("Institution") // Institution | Student | Corporate
  status             String   @default("Pending") // Pending | Contacted | Completed
  adminNotes         String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ExtractionJob {
  id              String   @id @default(uuid())
  name            String                        // "Medical Sciences OJS Import"
  sourceType      String                        // "OJS" | "URL" | "CSV" | "Manual"
  sourceConfig    Json                          // { baseUrl, domain hints, etc. }
  targetDomain    String?                       // Pre-filter domain, or null for auto-classify
  targetContentType String?                     // Pre-filter type, or null for auto-classify
  
  status          String   @default("Pending")  // Pending | Running | Completed | Failed
  
  totalDiscovered Int      @default(0)
  totalProcessed  Int      @default(0)
  totalInserted   Int      @default(0)
  totalDuplicates Int      @default(0)
  totalFailed     Int      @default(0)
  totalFlagged    Int      @default(0)          // Low-confidence items for review
  
  errorLog        Json     @default("[]")       // Array of error details
  
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           ExtractionItem[]
}

model ExtractionItem {
  id              String   @id @default(uuid())
  
  job             ExtractionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId           String
  
  rawData         Json                          // Original scraped data
  aiResult        Json?                         // AI classification output
  fingerprint     String?                       // Dedup fingerprint
  
  status          String   @default("Pending")  // Pending | Classified | Validated | Inserted | Duplicate | Failed | Flagged
  
  // Final mapped fields (after AI processing)
  title           String?
  authors         String?
  description     String?
  domain          String?
  contentType     String?
  subjectArea     String?
  fileUrl         String?
  tags            Json?    @default("[]")
  
  confidence      Float?   @default(0)          // AI confidence score
  validationResult Json?                        // PDF validation details
  errorMessage    String?
  
  contentId       String?                       // ID of inserted Content record (if successful)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([jobId, status])
  @@index([fingerprint])
}
