{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx -y tsx@4.7.1 server.ts",
    "build": "npx prisma generate && vite build && npm run build:server",
    "build:server": "esbuild server.ts --format=cjs --platform=node --bundle --external:@prisma/client --external:bcryptjs --external:jsonwebtoken --external:express --external:helmet --external:compression --external:nodemailer --external:razorpay --external:multer --external:@aws-sdk/client-s3 --external:@aws-sdk/s3-request-presigner --external:@aws-sdk/client-ses --external:@aws-sdk/client-sesv2 --external:dotenv --external:vite --external:sharp --external:fsevents --external:node-cron --outfile=server_compiled.cjs",
    "start": "npx prisma@6.19.3 db push --accept-data-loss && NODE_ENV=production node server_compiled.cjs",
    "start:dev": "NODE_ENV=production tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.967.0",
    "@aws-sdk/client-sesv2": "^3.967.0",
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^4.8.69",
    "prop-types": "^15.8.1",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "react-simple-maps": "^3.0.0",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-scale": "^4.0.9",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^5.4.21"
  }
}
